# Krita source (large; fetched/extracted separately, not part of the tooling repo)
krita-src/

# Upstream dep repos (cloned by the build; arm64 patches tracked separately)
krita-deps-management/
krita-ci-utilities/
deps-build/

# Build output / Craft root if ever placed inside the repo
CraftRoot/
build/
install/
*.log

# OS / editor cruft
Thumbs.db
desktop.ini
.vs/
.vscode/
*.user

# Build log written by build-krita-arm64.bat
build-log.txt

# Release binaries (uploaded to GitHub Releases, not tracked)
packaging/arm64-installer/*.exe
packaging/arm64-installer/*.zip
