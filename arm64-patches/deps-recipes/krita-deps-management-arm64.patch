diff --git a/ext_boost/CMakeLists.txt b/ext_boost/CMakeLists.txt
index 7b6ccd4..222b21c 100644
--- a/ext_boost/CMakeLists.txt
+++ b/ext_boost/CMakeLists.txt
@@ -78,7 +78,13 @@ if(WIN32)
             )
         endif()
     else()
-        set (BUILD_ARGS -j${SUBMAKE_JOBS} --with-system --build-dir=build-dir toolset=msvc variant=release link=shared threading=multi architecture=x86 install)
+        # arm64 needs architecture=arm; x64/x86 use architecture=x86 (b2 naming)
+        if (CMAKE_SYSTEM_PROCESSOR MATCHES "ARM64|aarch64|arm64")
+            set(KRITA_BOOST_B2_ARCH arm)
+        else()
+            set(KRITA_BOOST_B2_ARCH x86)
+        endif()
+        set (BUILD_ARGS -j${SUBMAKE_JOBS} --with-system --build-dir=build-dir toolset=msvc variant=release link=shared threading=multi architecture=${KRITA_BOOST_B2_ARCH} address-model=64 install)
 
         # Boost.Build cannot append arbitrary flags to MSVC from the command line.
         # It becomes unable to detect the target architecture or defaults to x86 only.
@@ -90,6 +96,10 @@ if(WIN32)
             URL https://archives.boost.io/release/1.81.0/source/boost_1_81_0.tar.bz2
             URL_HASH SHA256=71feeed900fbccca04a3b4f2f84a7c217186f28a940ed8b7ed4725986baf99fa
 
+            # Hardened Windows won't run config_toolset.bat from the cwd (system policy),
+            # and `call <name>.bat` doesn't reliably search PATH here, so boost's engine
+            # build can't detect msvc. Rewrite the bare calls to explicit %~dp0 paths.
+            PATCH_COMMAND sed -i -e [[s/call guess_toolset.bat/call "%~dp0guess_toolset.bat"/]] -e [[s/call config_toolset.bat/call "%~dp0config_toolset.bat"/]] <SOURCE_DIR>/tools/build/src/engine/build.bat
             CONFIGURE_COMMAND <SOURCE_DIR>/bootstrap.bat msvc --prefix=${EXTPREFIX}
             BUILD_COMMAND ${CMAKE_COMMAND} -DPREFIX=${EXTPREFIX} -P ${CMAKE_CURRENT_SOURCE_DIR}/run-b2-with-destdir.cmake -- ${BUILD_ARGS}
             INSTALL_COMMAND ${CMAKE_COMMAND} -DPREFIX=${EXTPREFIX} -P ${CMAKE_CURRENT_SOURCE_DIR}/run-b2-with-destdir.cmake -- ${BUILD_ARGS} install
@@ -104,13 +114,19 @@ if(WIN32)
         else()
             set(KRITA_boost_COMPILER_VERSION ${MSVC_TOOLSET_VERSION})
         endif()
-        ExternalProject_Add_Step(
-            ext_boost
-            pre_install
-            COMMAND ${CMAKE_COMMAND} -DSRC=<SOURCE_DIR>/build-dir/boost/bin.v2/libs/system/build/vc-${KRITA_boost_COMPILER_VERSION}/release/threading-multi/visibility-hidden/boost_system-vc${KRITA_boost_COMPILER_VERSION}-mt-x32-1_81.dll -DDST=${EXTPREFIX}/bin -P ${KRITA_CI_INSTALL}
-            COMMAND ${CMAKE_COMMAND} -DSRC=<SOURCE_DIR>/build-dir/boost/bin.v2/libs/system/build/vc-${KRITA_boost_COMPILER_VERSION}/release/threading-multi/visibility-hidden/boost_system-vc${KRITA_boost_COMPILER_VERSION}-mt-x64-1_81.dll -DDST=${EXTPREFIX}/bin -P ${KRITA_CI_INSTALL}
-            DEPENDERS install
-        )
+        # On arm64, b2 can't build the compiled boost_system stub (boost 1.81
+        # msvc.jam has no ARM64 support) and boost::system is header-only anyway,
+        # so there's no DLL to copy. Skip this step on arm64 (the x32/x64 paths
+        # wouldn't match arm64 regardless).
+        if (NOT (CMAKE_SYSTEM_PROCESSOR MATCHES "ARM64|aarch64|arm64"))
+            ExternalProject_Add_Step(
+                ext_boost
+                pre_install
+                COMMAND ${CMAKE_COMMAND} -DSRC=<SOURCE_DIR>/build-dir/boost/bin.v2/libs/system/build/vc-${KRITA_boost_COMPILER_VERSION}/release/threading-multi/visibility-hidden/boost_system-vc${KRITA_boost_COMPILER_VERSION}-mt-x32-1_81.dll -DDST=${EXTPREFIX}/bin -P ${KRITA_CI_INSTALL}
+                COMMAND ${CMAKE_COMMAND} -DSRC=<SOURCE_DIR>/build-dir/boost/bin.v2/libs/system/build/vc-${KRITA_boost_COMPILER_VERSION}/release/threading-multi/visibility-hidden/boost_system-vc${KRITA_boost_COMPILER_VERSION}-mt-x64-1_81.dll -DDST=${EXTPREFIX}/bin -P ${KRITA_CI_INSTALL}
+                DEPENDERS install
+            )
+        endif()
     endif()
 elseif(ANDROID)
     set (BUILD_ARGS --with-libraries=system --boost=1.81.0 --arch=${ANDROID_ABI} ${CMAKE_ANDROID_NDK})
diff --git a/ext_boost/run-b2-with-destdir.cmake b/ext_boost/run-b2-with-destdir.cmake
index e4bdef4..4e6b368 100644
--- a/ext_boost/run-b2-with-destdir.cmake
+++ b/ext_boost/run-b2-with-destdir.cmake
@@ -14,7 +14,9 @@ endif()
 
 if (NOT DEFINED B2_COMMAND)
     if(WIN32)
-        set(B2_COMMAND "b2")
+        # Hardened Windows won't exec b2 from the cwd; use its absolute path.
+        # In `cmake -P` mode CMAKE_BINARY_DIR is the invoking cwd (boost source).
+        set(B2_COMMAND "${CMAKE_BINARY_DIR}/b2.exe")
     else()
         set(B2_COMMAND "./b2")
     endif()
@@ -44,5 +46,14 @@ message ("Running b2 with args: --prefix=${PREFIX} ${EXTRA_ARGS}")
 
 exec_program(${B2_COMMAND} ARGS --prefix=${PREFIX} ${EXTRA_ARGS} RETURN_VALUE RETVAL)
 if (RETVAL)
-    message(FATAL_ERROR "failed to run b2")
+    # On Windows arm64, boost 1.81's msvc.jam has no ARM64 support, so b2 cannot
+    # build the (header-only since 1.69, empty-stub) compiled libs and returns
+    # nonzero. The headers + CMake config still install, which is all that's
+    # needed for header-only components like boost::system. Tolerate the skip
+    # iff the headers actually installed; otherwise it's a real failure.
+    if (EXISTS "${PREFIX}/include/boost-1_81/boost/system.hpp")
+        message(WARNING "b2 returned ${RETVAL}: compiled libs skipped (boost is header-only here); headers+config installed, continuing.")
+    else()
+        message(FATAL_ERROR "failed to run b2")
+    endif()
 endif()
\ No newline at end of file
diff --git a/ext_openexr/CMakeLists.txt b/ext_openexr/CMakeLists.txt
index 6d5729b..ca6575b 100644
--- a/ext_openexr/CMakeLists.txt
+++ b/ext_openexr/CMakeLists.txt
@@ -15,6 +15,11 @@ ExternalProject_Add( ext_openexr
     INSTALL_DIR ${EXTPREFIX}
     CMAKE_ARGS -DCMAKE_INSTALL_PREFIX=${EXTPREFIX} -DCMAKE_BUILD_TYPE=${GLOBAL_BUILD_TYPE} ${GLOBAL_PROFILE} -DNAMESPACE_VERSIONING=OFF
 
+    # ImfSimd.h enables IMF_HAVE_SSE2 for ANY MSVC (_MSC_VER>=1300), wrongly
+    # including <emmintrin.h> on arm64 (C1189). Gate SSE2 on x86/x64 only;
+    # arm64 then uses the scalar fallback.
+    PATCH_COMMAND sed -i [[s/!_M_CEE_PURE)/!_M_CEE_PURE \&\& (defined(_M_X64) || defined(_M_IX86)))/]] <SOURCE_DIR>/OpenEXR/IlmImf/ImfSimd.h
+
     UPDATE_COMMAND ""
 )
 
diff --git a/ext_openssl/CMakeLists.txt b/ext_openssl/CMakeLists.txt
